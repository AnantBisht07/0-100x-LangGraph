# Conversational Planner Agent - Environment Configuration

# OpenRouter API Key (Required)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# Optional: Future API Keys (for real implementations)

# Whisper API (for real voice processing)
# WHISPER_API_KEY=your-whisper-key

# GPT-4 Vision API (for real image processing)
# VISION_API_KEY=your-vision-key

# Optional: Configuration

# LLM Model
# MODEL_NAME=gpt-4o-mini

# Temperature (0-1)
# TEMPERATURE=0

# Compression Settings
# COMPRESSION_THRESHOLD=5
# RECENT_WINDOW_SIZE=4

# Debug Mode
# DEBUG=false
